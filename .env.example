# ─── Variáveis OBRIGATÓRIAS ────────────────────────────────

# Token do bot Discord (Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# Application ID do bot (Developer Portal → General Information)
DISCORD_CLIENT_ID=

# Chave da API AudD para detecção de música (https://audd.io)
AUDD_API_KEY=

# OpenAI (transcrição de áudio + sugestões virais)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Porta HTTP — Railway define automaticamente. Local: qualquer valor.
PORT=8080

# ─── Opcional ──────────────────────────────────────────────

# DATABASE_URL=  # Não usada hoje (bot usa SQLite local)
# NODE_ENV=production
